{
  "family": "libraryai-iep0",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "iep0",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-iep0:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8006,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",        "value": "/app" },
        { "name": "IEP0_MODELS_DIR",  "value": "/app/models/iep0" },
        { "name": "IEP0_MOCK_MODE",   "value": "false" }
      ],
      "resourceRequirements": [
        {
          "type": "GPU",
          "value": "1"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-iep0",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "iep0"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8006/ready || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
