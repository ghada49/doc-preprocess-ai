{
  "family": "libraryai-drain-monitor",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "drain-monitor",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-eep:latest",
      "essential": true,
      "command": [
        "python",
        "scripts/ecs_scaler/drain_monitor.py"
      ],
      "environment": [
        { "name": "PYTHONPATH", "value": "/app" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/DATABASE_URL" },
        { "name": "REDIS_URL",    "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/REDIS_URL" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-drain-monitor",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "drain-monitor"
        }
      }
    }
  ]
}
