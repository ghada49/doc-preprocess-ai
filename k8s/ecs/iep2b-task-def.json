{
  "family": "libraryai-iep2b",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "iep2b",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-iep2b:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8005,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",             "value": "/app" },
        { "name": "IEP2B_USE_REAL_MODEL",  "value": "true" },
        { "name": "IEP2B_MODELS_DIR",      "value": "/opt/models/iep2b" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-iep2b",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "iep2b"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8005/ready || exit 1"],
        "interval": 15,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 90
      }
    }
  ]
}
