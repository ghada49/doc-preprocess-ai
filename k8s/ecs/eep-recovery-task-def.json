{
  "family": "libraryai-eep-recovery",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "eep-recovery",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-eep-recovery:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "health",
          "containerPort": 9101,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",               "value": "/app" },
        { "name": "HEALTH_PORT",              "value": "9101" },
        { "name": "GOOGLE_ENABLED",           "value": "false" },
        { "name": "S3_BUCKET_NAME",           "value": "libraryai" },
        { "name": "WORKER_TASK_TIMEOUT_SECONDS", "value": "900" },
        { "name": "MAX_CONCURRENT_PAGES",     "value": "2" },
        { "name": "GPU_BACKEND",              "value": "local" },
        { "name": "PROMETHEUS_MULTIPROC_DIR", "value": "/tmp/prometheus_multiproc" },
        { "name": "IEP2A_LAYOUT_BACKEND",    "value": "paddleocr" },
        { "name": "IEP0_URL",                 "value": "http://iep0:8006" },
        { "name": "IEP1A_URL",                "value": "http://iep1a:8001" },
        { "name": "IEP1B_URL",                "value": "http://iep1b:8002" },
        { "name": "IEP1D_URL",                "value": "http://iep1d:8003" },
        { "name": "IEP1E_URL",                "value": "http://iep1e:8007" },
        { "name": "IEP2A_URL",                "value": "http://iep2a:8004" },
        { "name": "IEP2B_URL",                "value": "http://iep2b:8005" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",         "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/DATABASE_URL" },
        { "name": "REDIS_URL",            "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/REDIS_URL" },
        { "name": "JWT_SECRET_KEY",       "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/JWT_SECRET_KEY" },
        { "name": "S3_ACCESS_KEY_ID",     "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/S3_ACCESS_KEY_ID" },
        { "name": "S3_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/S3_SECRET_ACCESS_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-eep-recovery",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "eep-recovery"
        }
      },
      "stopTimeout": 120,
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:9101/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      }
    }
  ]
}
