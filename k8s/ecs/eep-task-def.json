{
  "family": "libraryai-eep",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "eep",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-eep:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",                   "value": "/app" },
        { "name": "S3_BUCKET_NAME",               "value": "libraryai2" },
        { "name": "POLICY_VERSION",               "value": "v1" },
        { "name": "CORS_ALLOW_ORIGINS",           "value": "*" },
        { "name": "PROMETHEUS_MULTIPROC_DIR",     "value": "/tmp/prometheus_multiproc" },
        { "name": "PROCESSING_START_MODE",        "value": "immediate" },
        { "name": "ECS_CLUSTER",                  "value": "CLUSTER_NAME" },
        { "name": "GPU_ASG_NAME",                 "value": "GPU_ASG_NAME" },
        { "name": "GPU_ASG_DESIRED",              "value": "1" },
        { "name": "RUNPOD_POD_MODE",              "value": "RUNPOD_POD_MODE_VALUE" },
        { "name": "RUNPOD_IEP0_POD_ID",           "value": "RUNPOD_IEP0_POD_ID_VALUE" },
        { "name": "RUNPOD_IEP1A_POD_ID",          "value": "RUNPOD_IEP1A_POD_ID_VALUE" },
        { "name": "RUNPOD_IEP1B_POD_ID",          "value": "RUNPOD_IEP1B_POD_ID_VALUE" },
        { "name": "RUNPOD_GPU_TYPE_ID",           "value": "RUNPOD_GPU_TYPE_ID_VALUE" },
        { "name": "RUNPOD_GPU_TYPES",             "value": "RUNPOD_GPU_TYPES_VALUE" },
        { "name": "RUNPOD_CLOUD_TYPE",            "value": "RUNPOD_CLOUD_TYPE_VALUE" },
        { "name": "RUNPOD_CLOUD_TYPES",           "value": "RUNPOD_CLOUD_TYPES_VALUE" },
        { "name": "RUNPOD_CONTAINER_DISK_GB",     "value": "RUNPOD_CONTAINER_DISK_GB_VALUE" },
        { "name": "RUNPOD_MIN_VCPU_PER_GPU",      "value": "RUNPOD_MIN_VCPU_PER_GPU_VALUE" },
        { "name": "RUNPOD_MIN_RAM_PER_GPU",       "value": "RUNPOD_MIN_RAM_PER_GPU_VALUE" },
        { "name": "WORKER_DESIRED_COUNT",         "value": "2" },
        { "name": "RETRAINING_WORKER_START_MODE", "value": "runpod_pod" },
        { "name": "RUNPOD_IMAGE",                  "value": "gma51/libraryai-retraining-worker:latest" },
        { "name": "RUNPOD_GPU_TYPES",              "value": "NVIDIA GeForce RTX 3090,NVIDIA RTX A5000,NVIDIA GeForce RTX 4090" },
        { "name": "RUNPOD_CLOUD_TYPE",             "value": "SECURE" },
        { "name": "RUNPOD_INTERRUPTIBLE",          "value": "false" },
        { "name": "RUNPOD_CONTAINER_DISK_GB",      "value": "80" },
        { "name": "RUNPOD_VOLUME_GB",              "value": "50" },
        { "name": "RUNPOD_TERMINATE_ON_IDLE",      "value": "true" },
        { "name": "RUNPOD_TERMINATE_ON_CALLBACK",  "value": "true" },
        { "name": "RETRAINING_CALLBACK_BASE_URL",  "value": "RETRAINING_CALLBACK_BASE_URL_VALUE" },
        { "name": "MLFLOW_TRACKING_URI",           "value": "http://mlflow.libraryai.local:5000" },
        { "name": "RETRAINING_MLFLOW_EXPERIMENT",  "value": "libraryai_preprocessing" },
        { "name": "LIBRARYAI_RETRAINING_TRAIN",    "value": "live" },
        { "name": "LIBRARYAI_RETRAINING_GOLDEN_EVAL", "value": "live" },
        { "name": "RETRAINING_DATASET_MODE",       "value": "corrected_hybrid" },
        { "name": "RETRAINING_DATASET_REGISTRY_PATH", "value": "s3://libraryai2/retraining/dataset_registry.json" },
        { "name": "IEP1A_WEIGHTS_URI",             "value": "IEP1A_WEIGHTS_URI_VALUE" },
        { "name": "IEP1B_WEIGHTS_URI",             "value": "IEP1B_WEIGHTS_URI_VALUE" },
        { "name": "AWS_REGION",                   "value": "REGION" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",         "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/DATABASE_URL" },
        { "name": "REDIS_URL",            "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/REDIS_URL" },
        { "name": "JWT_SECRET_KEY",       "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/JWT_SECRET_KEY" },
        { "name": "RUNPOD_API_KEY",       "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/RUNPOD_API_KEY" },
        { "name": "RETRAINING_CALLBACK_SECRET", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/RETRAINING_CALLBACK_SECRET" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-eep",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "eep"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8000/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
