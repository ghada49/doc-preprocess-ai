{
  "family": "libraryai-iep1e",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "8192",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "iep1e",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-iep1e:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8007,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",       "value": "/app" },
        { "name": "IEP1E_PORT",       "value": "8007" },
        { "name": "IEP1E_MOCK_MODE",  "value": "false" },
        { "name": "IEP1E_MODEL_DIR",  "value": "/opt/models/iep1e" }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8007/health', timeout=10).read()\" || exit 1"
        ],
        "interval": 30,
        "timeout": 15,
        "retries": 5,
        "startPeriod": 300
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-iep1e",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "iep1e"
        }
      }
    }
  ]
}
