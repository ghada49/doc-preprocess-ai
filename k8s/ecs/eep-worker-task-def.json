{
  "family": "libraryai-eep-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "eep-worker",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-eep-worker:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9100,
          "protocol": "tcp",
          "name": "health"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",    "value": "/app" },
        { "name": "HEALTH_PORT",   "value": "9100" },
        { "name": "GOOGLE_ENABLED",              "value": "GOOGLE_ENABLED_VALUE" },
        { "name": "GOOGLE_PROJECT_ID",           "value": "GOOGLE_PROJECT_ID_VALUE" },
        { "name": "GOOGLE_LOCATION",             "value": "GOOGLE_LOCATION_VALUE" },
        { "name": "GOOGLE_PROCESSOR_ID_LAYOUT",  "value": "GOOGLE_PROCESSOR_ID_LAYOUT_VALUE" },
        { "name": "S3_BUCKET_NAME", "value": "libraryai2" },
        { "name": "WORKER_TASK_TIMEOUT_SECONDS", "value": "900" },
        { "name": "WORKER_TASK_HEARTBEAT_SECONDS", "value": "60" },
        { "name": "MAX_CONCURRENT_PAGES", "value": "4" },
        { "name": "GPU_BACKEND",   "value": "local" },
        { "name": "PROMETHEUS_MULTIPROC_DIR", "value": "/tmp/prometheus_multiproc" },
        { "name": "IEP2A_LAYOUT_BACKEND", "value": "paddleocr" },
        { "name": "MLFLOW_TRACKING_URI", "value": "http://mlflow.libraryai.local:5000" },
        { "name": "COLD_START_TIMEOUT_SECONDS", "value": "600" },
        { "name": "IEP0_URL",  "value": "IEP0_URL_VALUE" },
        { "name": "IEP1A_URL", "value": "IEP1A_URL_VALUE" },
        { "name": "IEP1B_URL", "value": "IEP1B_URL_VALUE" },
        { "name": "IEP1D_URL", "value": "http://iep1d:8003" },
        { "name": "IEP1D_SCALER_MODE",                  "value": "ecs" },
        { "name": "IEP1D_SERVICE_NAME",                  "value": "libraryai-iep1d" },
        { "name": "ECS_CLUSTER",                          "value": "CLUSTER_NAME" },
        { "name": "IEP1D_READY_URL",                      "value": "http://iep1d.libraryai.local:8003/ready" },
        { "name": "IEP1D_SCALE_TIMEOUT_SECONDS",         "value": "1200" },
        { "name": "IEP1D_READY_TIMEOUT_SECONDS",         "value": "1200" },
        { "name": "IEP1D_SCALE_DOWN_AFTER_IDLE_SECONDS", "value": "300" },
        { "name": "IEP1E_URL", "value": "IEP1E_URL_VALUE" },
        { "name": "IEP1E_READY_TIMEOUT_SECONDS", "value": "600" },
        { "name": "IEP1E_READY_POLL_INTERVAL_SECONDS", "value": "5" },
        { "name": "IEP2A_URL", "value": "IEP2A_URL_VALUE" },
        { "name": "IEP2B_URL", "value": "IEP2B_URL_VALUE" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",           "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/DATABASE_URL" },
        { "name": "REDIS_URL",             "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/REDIS_URL" },
        { "name": "JWT_SECRET_KEY",        "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/JWT_SECRET_KEY" },
        { "name": "GOOGLE_CREDENTIALS_JSON", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:libraryai/GOOGLE_CREDENTIALS_JSON" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-eep-worker",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "eep-worker"
        }
      },
      "stopTimeout": 120,
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:9100/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      }
    }
  ]
}
