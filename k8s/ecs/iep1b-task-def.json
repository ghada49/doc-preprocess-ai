{
  "family": "libraryai-iep1b",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "cpu": "2048",
  "memory": "6144",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "iep1b",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/libraryai-iep1b:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8002,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH",        "value": "/app" },
        { "name": "IEP1B_MOCK_MODE",  "value": "false" },
        { "name": "IEP1B_MODELS_DIR", "value": "/app/models/iep1b" }
      ],
      "resourceRequirements": [
        {
          "type": "GPU",
          "value": "1"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-iep1b",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "iep1b"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8002/ready || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
