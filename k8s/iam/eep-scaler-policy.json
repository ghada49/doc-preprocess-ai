      "Resource": [
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-iep0",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-iep1a",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-iep1b",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-iep1e",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-iep2a",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-iep2b",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-eep-worker",
        "arn:aws:ecs:eu-central-1:181137999093:service/libraryai-staging/libraryai-eep-recovery",
