# ── Admin bootstrap ───────────────────────────────────────────────────────────
# If set, the EEP container will create this admin account on first start
# (no-op if the username already exists).
# Leave BOOTSTRAP_ADMIN_PASSWORD blank to disable automatic bootstrap.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=libraryai
POSTGRES_USER=libraryai
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg2://libraryai:changeme@postgres:5432/libraryai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Object storage (MinIO) ────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=libraryai
S3_REGION=us-east-1
S3_CONNECT_TIMEOUT_SECONDS=5
S3_READ_TIMEOUT_SECONDS=60
S3_MAX_RETRIES=3
S3_MAX_POOL_CONNECTIONS=10

# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: replace with a long random secret before any deployment
JWT_SECRET_KEY=changeme-replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated origins allowed to call the EEP API from browsers.
# Keep this aligned with the frontend origin for split-origin local dev or deploys.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Internal service URLs (Docker network) ────────────────────────────────────
IEP1A_URL=http://iep1a:8001
IEP1B_URL=http://iep1b:8002
IEP1D_URL=http://iep1d:8003
IEP2A_URL=http://iep2a:8004
IEP2B_URL=http://iep2b:8005

# -- Layout detector serving ---------------------------------------------------
# Build args consumed by docker-compose.yml
IEP2A_ENABLE_REAL_MODEL=false
IEP2A_ENABLE_PADDLE_BACKEND=false
IEP2B_ENABLE_REAL_MODEL=false

# -- IEP1D rectification serving -----------------------------------------------
IEP1D_WEIGHTS_PATH=/opt/models/iep1d/best_model.pkl
IEP1D_MODEL_VERSION=uvdoc-official
IEP1D_DEVICE=auto
IEP1D_LOCAL_WEIGHTS_DIR=./models/iep1d
IEP1D_LOCAL_WEIGHTS_PATH=
# Example override value when using docker-compose development mounts:
# IEP1D_LOCAL_WEIGHTS_PATH=/dev-models/iep1d/best_model.pkl

# Runtime toggles
IEP2A_USE_REAL_MODEL=false
IEP2A_LAYOUT_BACKEND=detectron2
IEP2B_USE_REAL_MODEL=false

# Production defaults: approved weights baked into the image
# Each baked checkpoint should also include a matching `<weights>.version` file.
IEP2A_WEIGHTS_PATH=/opt/models/iep2a/model_final.pth
IEP2A_CONFIG_PATH=
# Validation/override input; baked `<weights>.version` remains authoritative.
IEP2A_MODEL_VERSION=detectron2-publaynet-r50-fpn-3x
IEP2B_WEIGHTS_PATH=/opt/models/iep2b/doclayout_yolo_docstructbench_imgsz1024.pt
# Validation/override input; baked `<weights>.version` remains authoritative.
IEP2B_MODEL_VERSION=doclayout-yolo-docstructbench

# Optional development-only overrides for mounted local artifacts
IEP2A_LOCAL_WEIGHTS_DIR=./models/iep2a
IEP2A_LOCAL_WEIGHTS_PATH=
IEP2A_PADDLE_MODEL_DIR=/opt/models/iep2a/paddle/PP-DocLayoutV2
IEP2A_PADDLE_LOCAL_MODEL_DIR=
IEP2A_PADDLE_MODEL_VERSION=
IEP2A_PADDLE_ALLOW_ONLINE_DOWNLOAD=false
IEP2A_PADDLE_MODEL_SOURCE=
IEP2A_PADDLE_DISABLE_MODEL_SOURCE_CHECK=true
IEP2A_PADDLE_DEVICE=cpu
IEP2B_LOCAL_WEIGHTS_DIR=./models/iep2b
IEP2B_LOCAL_WEIGHTS_PATH=
# Example override values when using docker-compose development mounts:
# IEP2A_LOCAL_WEIGHTS_PATH=/dev-models/iep2a/model_final.pth
# IEP2A_PADDLE_LOCAL_MODEL_DIR=/dev-models/iep2a/paddle/PP-DocLayoutV2
# IEP2B_LOCAL_WEIGHTS_PATH=/dev-models/iep2b/doclayout_yolo_docstructbench_imgsz1024.pt

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Retraining worker (optional live train + golden eval) ─────────────────────
# Default: stub training + stub gates. For real runs:
#   LIBRARYAI_RETRAINING_TRAIN=live   — runs training/scripts/train_iep{0,1a,1b}.py
#   LIBRARYAI_RETRAINING_GOLDEN_EVAL=live — runs evaluate_golden_dataset (needs AWS + manifest)
# Live training needs dataset paths — either a JSON manifest:
#   RETRAINING_TRAIN_MANIFEST=/path/to/retraining_train_manifest.json
# with shape:
#   {"iep0":{"data_root":"/abs/ImageFolder"},"iep1a":{"book":"/abs/book/data.yaml",...},"iep1b":{...}}
# or individual env vars (all required if manifest unset):
#   RETRAINING_IEP0_DATA_ROOT=...
#   RETRAINING_IEP1A_BOOK_YAML=...  RETRAINING_IEP1A_NEWSPAPER_YAML=...  RETRAINING_IEP1A_MICROFILM_YAML=...
#   RETRAINING_IEP1B_BOOK_YAML=...  RETRAINING_IEP1B_NEWSPAPER_YAML=...  RETRAINING_IEP1B_MICROFILM_YAML=...
# Optional:
#   RETRAINING_DATASET_VERSION=...   (else derived from job id)
#   RETRAINING_DATASET_MODE=corrected_only|corrected_hybrid
#   RETRAINING_DATASET_REGISTRY_PATH=training/preprocessing/dataset_registry.json
#   RETRAINING_DATASET_BUILDER_CMD="python services/dataset_builder/app/main.py --mode corrected-export"
#   RETRAINING_DATASET_BUILDER_TIMEOUT=1800
#   RETRAINING_DEVICE=cpu            (or 0 for first CUDA device)
#   RETRAINING_IEP0_MODE=stub        (IEP0 bypassed while corrected-data retraining focuses on IEP1A/B)
#   RETRAINING_QUICK=1               — --epochs 1 on all train scripts (smoke)
#   RETRAINING_SUBPROCESS_TIMEOUT=86400
#   GOLDEN_SKIP_CROSS_MODEL=1        — faster live golden (no IEP1A/B cross-model pass)
LIBRARYAI_RETRAINING_TRAIN=stub
LIBRARYAI_RETRAINING_GOLDEN_EVAL=stub
RETRAINING_IEP0_MODE=stub
RETRAINING_DATASET_MODE=corrected_hybrid
# RETRAINING_DATASET_REGISTRY_PATH=training/preprocessing/dataset_registry.json
# RETRAINING_DATASET_BUILDER_CMD=
# RETRAINING_DATASET_BUILDER_TIMEOUT=1800
# RETRAINING_TRAIN_MANIFEST=
#
# Step 7 (E2E): after setting live flags + manifest, merge compose overlay and run:
#   docker compose -f docker-compose.yml -f docker-compose.step7.yml up -d
#   python scripts/run_step7_e2e.py
# EEP_BASE_URL=http://127.0.0.1:8000 STEP7_WAIT_SECONDS=7200

# ── Worker ────────────────────────────────────────────────────────────────────
MAX_CONCURRENT_PAGES=20
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=60
WORKER_TASK_TIMEOUT_SECONDS=900
WORKER_TASK_CHECK_INTERVAL_SECONDS=30
WORKER_TASK_HEARTBEAT_SECONDS=60
IEP1E_READY_TIMEOUT_SECONDS=120
IEP1E_READY_POLL_INTERVAL_SECONDS=5
LAYOUT_ARTIFACT_IO_TIMEOUT_SECONDS=45
LAYOUT_ARTIFACT_IO_ATTEMPTS=3
LAYOUT_ARTIFACT_IO_BACKOFF_SECONDS=1
RECOVERY_TASK_TIMEOUT_SECONDS=900
RECOVERY_LAYOUT_TASK_TIMEOUT_SECONDS=180
RECOVERY_CHECK_INTERVAL_SECONDS=30
RECOVERY_DEAD_LETTER_WARNING_THRESHOLD=100

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ── GPU backend ───────────────────────────────────────────────────────────────
# "local" for Docker-based HTTP backend; "runpod" for production
GPU_BACKEND=local
COLD_START_TIMEOUT_SECONDS=120
EXECUTION_TIMEOUT_SECONDS=30
IEP1D_EXECUTION_TIMEOUT_SECONDS=180
# Runpod credentials (required when GPU_BACKEND=runpod)
RUNPOD_API_KEY=

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# ── Worker health ports (internal Docker network only, not exposed to host) ───
# These must match the HEALTH_PORT values in docker-compose.yml
EEP_WORKER_HEALTH_PORT=9100
EEP_RECOVERY_HEALTH_PORT=9101
SHADOW_WORKER_HEALTH_PORT=9102
SHADOW_RECOVERY_HEALTH_PORT=9103
RETRAINING_WORKER_HEALTH_PORT=9104
RETRAINING_RECOVERY_HEALTH_PORT=9105
ARTIFACT_CLEANUP_HEALTH_PORT=9106

# ── Policy ────────────────────────────────────────────────────────────────────
POLICY_VERSION=v1

# ── Google Document AI (optional; disabled by default) ────────────────────────
# Set GOOGLE_ENABLED=true to activate the Google Document AI fallback path.
# All non-secret settings live here.  The service account credentials file
# must be mounted separately — never paste JSON inline as an env var.
#
# Kubernetes (ops must apply externally):
#   Secret:     google-documentai-sa
#   mountPath:  /var/secrets/google   (readOnly: true)
#   key file:   /var/secrets/google/key.json
#
# Docker Compose local dev:
#   Set GOOGLE_CREDENTIALS_HOST_PATH to your host machine's key file path.
#   docker-compose.yml will bind-mount it to /var/secrets/google/key.json.
#
GOOGLE_CREDENTIALS_HOST_PATH=./google-credentials-stub.json
GOOGLE_ENABLED=false
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID_LAYOUT=
GOOGLE_PROCESSOR_ID_CLEANUP=
GOOGLE_TIMEOUT_LAYOUT_SECONDS=90
GOOGLE_TIMEOUT_CLEANUP_SECONDS=120
GOOGLE_MAX_RETRIES=2
GOOGLE_FALLBACK_ON_TIMEOUT=true
GOOGLE_CREDENTIALS_PATH=/var/secrets/google/key.json
