{
  "family": "libraryai-eep",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::181137999093:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::181137999093:role/libraryai-task-role",
  "containerDefinitions": [
    {
      "name": "eep",
      "image": "181137999093.dkr.ecr.eu-central-1.amazonaws.com/libraryai-eep:runpod-callback-20260430201645",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PYTHONPATH", "value": "/app" },
        { "name": "S3_BUCKET_NAME", "value": "libraryai2" },
        { "name": "POLICY_VERSION", "value": "v1" },
        { "name": "CORS_ALLOW_ORIGINS", "value": "*" },
        { "name": "PROMETHEUS_MULTIPROC_DIR", "value": "/tmp/prometheus_multiproc" },
        { "name": "PROCESSING_START_MODE", "value": "immediate" },
        { "name": "ECS_CLUSTER", "value": "libraryai-staging" },
        { "name": "GPU_ASG_NAME", "value": "GPU_ASG_NAME" },
        { "name": "GPU_ASG_DESIRED", "value": "1" },
        { "name": "WORKER_DESIRED_COUNT", "value": "2" },
        { "name": "RETRAINING_WORKER_START_MODE", "value": "runpod_pod" },
        { "name": "RUNPOD_IMAGE", "value": "gma51/libraryai-retraining-worker:latest" },
        {
          "name": "RUNPOD_GPU_TYPES",
          "value": "NVIDIA GeForce RTX 3090,NVIDIA RTX A5000,NVIDIA GeForce RTX 4090"
        },
        { "name": "RUNPOD_CLOUD_TYPE", "value": "SECURE" },
        { "name": "RUNPOD_INTERRUPTIBLE", "value": "false" },
        { "name": "RUNPOD_CONTAINER_DISK_GB", "value": "80" },
        { "name": "RUNPOD_VOLUME_GB", "value": "50" },
        { "name": "RUNPOD_TERMINATE_ON_IDLE", "value": "true" },
        { "name": "RUNPOD_TERMINATE_ON_CALLBACK", "value": "true" },
        {
          "name": "RETRAINING_CALLBACK_BASE_URL",
          "value": "http://libraryai-staging-alb-520535967.eu-central-1.elb.amazonaws.com"
        },
        { "name": "MLFLOW_TRACKING_URI", "value": "http://mlflow.libraryai.local:5000" },
        { "name": "LIBRARYAI_RETRAINING_TRAIN", "value": "stub" },
        { "name": "LIBRARYAI_RETRAINING_GOLDEN_EVAL", "value": "stub" },
        { "name": "RETRAINING_DATASET_MODE", "value": "corrected_hybrid" },
        {
          "name": "RETRAINING_DATASET_REGISTRY_PATH",
          "value": "s3://libraryai2/retraining/dataset_registry.json"
        },
        {
          "name": "IEP1A_WEIGHTS_URI",
          "value": "s3://libraryai2/models/iep1a/iep1a-models.tar.gz"
        },
        {
          "name": "IEP1B_WEIGHTS_URI",
          "value": "s3://libraryai2/models/iep1b/iep1b-models.tar.gz"
        },
        { "name": "AWS_REGION", "value": "eu-central-1" },
        { "name": "S3_REGION", "value": "eu-central-1" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/DATABASE_URL"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/REDIS_URL"
        },
        {
          "name": "JWT_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/JWT_SECRET_KEY"
        },
        {
          "name": "RUNPOD_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/RUNPOD_API_KEY"
        },
        {
          "name": "RETRAINING_CALLBACK_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/RETRAINING_CALLBACK_SECRET"
        },
        {
          "name": "S3_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/S3_ACCESS_KEY_ID"
        },
        {
          "name": "S3_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:181137999093:secret:libraryai/S3_SECRET_ACCESS_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/libraryai-eep",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "eep"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8000/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
